    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 3s linear infinite;
    position: relative;
    text-shadow: 0 0 30px rgba(220, 20, 60, 0.5);
  }
  
  .section-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 3px;
    background: linear-gradient(90deg, transparent, var(--primary-red), transparent);
    animation: underlineGrow 2s ease-out forwards;
    box-shadow: 0 0 10px var(--primary-red);
  }
  
  @keyframes shimmer {
    to { background-position: 200% center; }
  }
  
  @keyframes underlineGrow {
    to { width: 150px; }
  }
  
  .about-copy {
    max-width: 820px;
    margin: 0 auto;
  }

  .about-copy p {
    margin: 0;
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    line-height: 1.95;
    color: rgba(255, 255, 255, 0.92);
    text-align: center;
    text-shadow:
      0 0 16px rgba(220, 20, 60, 0.16),
      0 0 24px rgba(0, 0, 0, 0.72);
  }
  
  @keyframes badge-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; }
  }

  .post-intro-shell {
    position: relative;
    background: #000;
    isolation: isolate;
  }

  .post-intro-background {
    position: sticky;
    top: 0;
    height: 100vh;
    margin-bottom: -100vh;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .post-intro-background::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 58%, rgba(255, 40, 90, 0.12), transparent 34%),
      linear-gradient(180deg, rgba(0, 0, 0, 0.18), rgba(0, 0, 0, 0.02) 22%, rgba(0, 0, 0, 0.02) 78%, rgba(0, 0, 0, 0.32));
  }

  .post-intro-shell > section {
    position: relative;
    z-index: 1;
  }

  .results {
    position: relative;
    padding: 110px 20px;
    background: transparent;
    overflow: hidden;
  }

  .results::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.18), rgba(0, 0, 0, 0) 22%, rgba(0, 0, 0, 0) 78%, rgba(0, 0, 0, 0.3));
    pointer-events: none;
    z-index: 0;
  }

  .results-globe-shell {
    position: absolute;
    top: 42%;
    left: 50%;
    width: min(142vw, 1780px);
    height: min(142vw, 1780px);
    transform: translateX(-50%);
    opacity: 0.46;
    filter: drop-shadow(0 0 56px rgba(220, 20, 60, 0.18));
  }

  .results-globe {
    width: 100%;
    height: 100%;
  }

  .results .container {
    position: relative;
    z-index: 1;
    max-width: 1360px;
    margin: 0 auto;
  }

  .results-header {
    max-width: 760px;
    margin: 0 auto 3.5rem;
    text-align: center;
  }

  .results-header h2 {
    margin: 0;
    font-size: clamp(2.3rem, 5vw, 3.6rem);
    color: white;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .results-timeline {
    position: relative;
    display: grid;
    gap: 1.6rem;
    padding-left: 0.5rem;
    max-width: 1320px;
    width: 100%;
    margin: 0 auto;
  }

  .results-timeline::before {
    content: '';
    position: absolute;
    top: 0.75rem;
    bottom: 0.75rem;
    left: 2rem;
    width: 1px;
    background: linear-gradient(180deg, rgba(220, 20, 60, 0.35), rgba(220, 20, 60, 0.08));
  }

  .result-entry {
    position: relative;
    display: grid;
    grid-template-columns: 4rem minmax(0, 1fr);
    gap: 1.4rem;
    align-items: start;
  }

  .result-marker {
    display: flex;
    justify-content: center;
    padding-top: 0.15rem;
  }

  .result-logo-shell {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 50%;
    background: linear-gradient(180deg, rgba(19, 21, 35, 0.96), rgba(3, 4, 11, 0.96));
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow: 0 0 0 6px rgba(3, 3, 10, 0.92), 0 14px 30px rgba(0, 0, 0, 0.35);
  }

  .result-logo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .result-logo-fallback {
    color: var(--primary-red);
    font-size: 1.3rem;
  }

  .result-card {
    position: relative;
    padding: 1.45rem 1.55rem;
    border-radius: 18px;
    background: rgba(3, 3, 12, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .result-card:hover {
    transform: translateY(-4px);
    border-color: rgba(220, 20, 60, 0.45);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.42);
  }

  .result-date {
    margin: 0;
    color: rgba(255, 255, 255, 0.52);
    font-size: 0.88rem;
    letter-spacing: 0.08rem;
  }

  .result-title {
    display: inline-block;
    margin-bottom: 1rem;
    color: #ff748e;
    text-decoration: none;
    font-size: clamp(1.1rem, 2vw, 1.65rem);
    font-weight: 700;
    line-height: 1.25;
    transition: color 0.3s ease;
  }

  .result-title:hover {
    color: #ff98aa;
  }

  .result-rank-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #ff214d, #cb0f32);
    color: white;
    font-size: 0.9rem;
    font-weight: 700;
    box-shadow: 0 0 18px rgba(220, 20, 60, 0.28);
  }

  .result-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1.35rem;
  }

  .result-date-footer {
    flex: 1;
    align-self: center;
  }

  .result-points {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 0.7rem;
  }

  .result-point-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.78rem;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .result-point-chip-ctf {
    background: rgba(27, 35, 56, 0.92);
    color: #ffe0e5;
  }

  .result-point-chip-ctf i {
    color: #ff5a7b;
  }

  .result-point-chip-rating {
    background: rgba(9, 49, 72, 0.92);
    color: #d7f4ff;
  }

  .result-point-chip-rating i {
    color: #4fd4ff;
  }

  .result-empty {
    padding: 1.35rem 1.5rem;
    border-radius: 18px;
    background: rgba(3, 3, 12, 0.94);
    border: 1px dashed rgba(220, 20, 60, 0.3);
    color: rgba(255, 255, 255, 0.68);
    margin-left: 4.75rem;
  }
  
  /* Accordion Styles */
  .accordion-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .accordion-item {
    background: rgba(220, 20, 60, 0.03);
    border: 1px solid rgba(220, 20, 60, 0.2);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  
  .accordion-item.active {
    border-color: rgba(220, 20, 60, 0.5);
    background: rgba(220, 20, 60, 0.08);
  }
  
  .accordion-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    user-select: none;
  }
  
  .accordion-header:hover {
    background: rgba(220, 20, 60, 0.05);
  }
  
  .accordion-icon {
    font-size: 1.5rem;
    color: var(--primary-red);
    filter: drop-shadow(0 0 8px rgba(220, 20, 60, 0.6));
  }
  
  .accordion-header h4 {
    flex: 1;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary-red);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }
  
  .accordion-arrow {
    font-size: 1.2rem;
    color: var(--primary-red);
    transition: transform 0.3s ease;
  }
  
  .accordion-item.active .accordion-arrow {
    transform: rotate(180deg);
  }
  
  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s ease;
    padding: 0 1.5rem;
  }
  
  .accordion-item.active .accordion-content {
    max-height: 500px;
    padding: 0 1.5rem 1.5rem;
  }
  
  .accordion-content p {
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  .skill-details {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .skill-details li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    position: relative;
  }
  
  .skill-details li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--primary-red);
    font-weight: bold;
  }
  
  /* Services Section */
  .services {
    position: relative;
    z-index: 1;
    padding: 100px 20px;
    background-color: transparent;
    margin: 20px 0;
  }

  .services .container {
    max-width: 1360px;
    margin: 0 auto;
    padding-left: 5.9rem;
    padding-right: 0.5rem;
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 380px));
    justify-content: center;
    gap: 2rem;
  }
  
  .service-card {
    background: rgba(3, 3, 12, 0.94);
    padding: 2rem;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .services-grid > :nth-child(4):last-child {
    grid-column: 2;
  }
  
  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 2px;
    background-color: var(--primary-red);
    transition: left 0.3s ease;
  }
  
  .service-card:hover::before {
    left: 0;
  }
  
  .service-card:hover {
    transform: translateY(-5px);
    border-color: rgba(220, 20, 60, 0.45);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.42);
  }
  
  .service-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .service-icon i {
    color: #ff5a7b;
    font-size: 3rem;
  }
  
  .service-card h3 {
    color: #ff748e;
    margin-bottom: 1rem;
    font-size: 1.3rem;
  }
  
  .service-card p {
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.6;
  }

  .ctf-platform-card {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  /* Team Section */
  .team {
    position: relative;
    z-index: 1;
    padding: 100px 20px;
    background-color: transparent;
    margin: 20px 0;
  }
  
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .team-member {
    background-color: var(--black);
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
    border: 1px solid var(--light-gray);
    transition: all 0.3s ease;
  }
  
  .team-member:hover {
    transform: translateY(-5px);
    border-color: var(--primary-red);
  }

  /* Ensure terminal animation inside member cards is left-aligned */
  .team-member .terminal {
    display: block;
    text-align: left;
    margin-left: 0;
    margin-right: auto;
    width: auto;
    max-width: 500px;
  }
  
  .member-avatar {
    font-size: 4rem;
    margin-bottom: 1rem;
  }

  .member-avatar i {
    color: var(--primary-red);
    font-size: 4rem;
  }
  
  .team-member h3 {
    font-size: 0.9rem;
    letter-spacing: 1px;
  }
  
  .member-bio {
    font-size: 0.9rem;
    opacity: 0.8;
  }
  
  .member-email {
    font-size: 0.8rem;
    color: var(--primary-red);
    margin-top: 0.5rem;
    font-weight: bold;
  }
  
  /* Social Media Section */
  .social-media {
    position: relative;
    z-index: 1;
    padding: 100px 20px;
    background-color: transparent;
    margin: 20px 0;
  }
  
  .social-subtitle {
    text-align: center;
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 4rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .social-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .social-card {
    background: rgba(220, 20, 60, 0.03);
    border: 1px solid rgba(220, 20, 60, 0.2);
    border-radius: 12px;
    padding: 3rem 2rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  
  .social-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(220, 20, 60, 0.1), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  
  .social-card:hover::before {
    opacity: 1;
  }
  
  .social-card:hover {
    transform: translateY(-10px);
    border-color: rgba(220, 20, 60, 0.6);
    box-shadow: 0 20px 40px rgba(220, 20, 60, 0.3);
    background: rgba(220, 20, 60, 0.08);
  }
  
  .social-icon {
    width: 100px;
    height: 100px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle, rgba(220, 20, 60, 0.2), transparent);
    border-radius: 50%;
    border: 2px solid rgba(220, 20, 60, 0.3);
    transition: all 0.4s ease;
  }
  
  .social-card:hover .social-icon {
    transform: scale(1.1) rotate(5deg);
    border-color: rgba(220, 20, 60, 0.6);
    box-shadow: 0 0 30px rgba(220, 20, 60, 0.5);
  }
  
  .social-icon i {
    font-size: 3.5rem;
    color: var(--primary-red);
    filter: drop-shadow(0 0 10px rgba(220, 20, 60, 0.8));
    transition: all 0.4s ease;
  }
  
  .social-card:hover .social-icon i {
    filter: drop-shadow(0 0 20px rgba(220, 20, 60, 1));
  }
  
  .social-card h3 {
    font-size: 1.5rem;
    color: var(--primary-red);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
  }
  
  .social-card p {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    transition: color 0.3s ease;
  }
  
  .social-card:hover p {
    color: rgba(255, 255, 255, 0.9);
  }
  
  
  /* Footer */
  .footer {
    position: relative;
    z-index: 1;
    background-color: var(--black);
    padding: 3rem 20px 1rem;
    border-top: 2px solid var(--primary-red);
  }
  
  .footer-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    margin-bottom: 2rem;
  }
  
  .footer-brand .logo {
    color: var(--primary-red);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  
  .footer-tagline {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.5rem;
    font-style: italic;
  }
  
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  
  .footer-column h4 {
    color: var(--primary-red);
    margin-bottom: 1rem;
  }
  
  .footer-column ul {
    list-style: none;
  }
  
  .footer-column li {
    margin-bottom: 0.5rem;
  }
  
  .footer-column a {
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.3s ease;
    font-size: 0.95rem;
  }
  
  .footer-column a:hover {
    color: var(--primary-red);
  }
  
  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--light-gray);
    text-align: center;
  }
  
  .footer-bottom p {
    margin: 0.5rem 0;
  }
  
  .footer-subtitle {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.5rem;
  }
  
  .footer-warning {
    color: var(--primary-red);
    font-weight: bold;
  }

  .footer-warning i {
    color: var(--primary-red);
    font-size: 1rem;
    vertical-align: middle;
  }
  
  /* Responsive Design */
  @media (max-width: 768px) {
    .hero {
      min-height: 126vh;
      height: auto;
      padding: 0;
    }

    .hero-stage::after {
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.74) 0%, rgba(0, 0, 0, 0.58) 38%, rgba(0, 0, 0, 0.82) 100%),
        radial-gradient(circle at 50% 28%, rgba(255, 40, 90, 0.1), transparent 34%);
    }

    .hero-globe-shell {
      top: 50%;
      left: 50%;
      right: auto;
      width: min(86vw, 620px);
      height: min(86vw, 620px);
      transform: translate3d(-50%, -50%, 0);
      opacity: 0.64;
    }

    .hero-vignette {
      background:
        radial-gradient(circle at 50% 28%, rgba(255, 50, 95, 0.16), transparent 24%),
        linear-gradient(180deg, rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.3));
    }

    .hero-panel {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 80px 1rem 40px;
      min-height: 100%;
      align-items: start;
    }
    
    .hero-content {
      order: 1;
    }
    
    .hero-stats {
      order: 2;
      width: 100%;
      margin-bottom: 2rem;
      padding: 0;
      max-width: 100%;
    }
    
    .stats-card {
      padding: 1.5rem;
      width: 100%;
      max-width: 92%;
      margin: 0 auto;
    }
    
    .best-badge {
      font-size: 1rem;
      padding: 1rem 0.8rem;
      gap: 0.5rem;
    }
    
    .best-badge i {
      font-size: 1.5rem;
    }
    
    .best-badge .flag {
      font-size: 1.3rem;
    }
    
    .stat-item {
      padding: 0.8rem;
    }

    .stat-item i {
      font-size: 1.5rem;
    }
    
    .stat-value {
      font-size: 1.3rem;
    }

    .stat-label {
      font-size: 0.85rem;
    }
    
    .brand-identity {
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    
    .brand-logo {
      width: 100px;
      height: 100px;
    }
    
    .brand-name {
      font-size: 2.5rem;
      letter-spacing: 2px;
    }
    
    .hero-subtitle {
      font-size: 1.2rem;
      letter-spacing: 2px;
      margin-bottom: 1.5rem;
    }
    
    .hero-description {
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 2rem;
      padding: 0;
    }
    
    .hero-buttons {
      flex-direction: column;
      padding: 0;
      gap: 1rem;
    }
    
    .hero-buttons .btn {
      width: 100%;
    }
    
    .about-panel {
      padding: 5rem 16px;
    }

    .about-panel .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .about-copy p {
      font-size: 1rem;
      line-height: 1.8;
    }
    
    .results {
      padding: 90px 16px 120px;
    }

    .results-header {
      margin-bottom: 2.5rem;
    }

    .results-globe-shell {
      top: 52%;
      width: min(196vw, 1120px);
      height: min(196vw, 1120px);
      opacity: 0.34;
    }

    .results-timeline {
      padding-left: 0;
    }

    .results-timeline::before {
      display: none;
    }

    .result-entry {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }

    .result-marker {
      justify-content: flex-start;
      padding-left: 1rem;
    }

    .result-card {
      padding: 1.25rem;
    }

    .result-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .result-points {
      justify-content: flex-start;
    }

    .result-empty {
      margin-left: 0;
    }
    
    .services-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .services .container {
      padding-left: 0;
      padding-right: 0;
    }

    .services-grid > :nth-child(4):last-child {
      grid-column: auto;
    }

    .team-grid {
      grid-template-columns: 1fr;
    }
    
    .social-links {
      grid-template-columns: 1fr;
      gap: 1.5rem;
