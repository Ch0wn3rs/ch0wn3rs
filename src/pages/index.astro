---
import Layout from '../layouts/Layout.astro';
import '@phosphor-icons/web/regular';
import { fetchCtftime } from '../lib/ctftime';
import { animate, stagger } from 'animejs';

const TEAM_ID = '408704';
const ctftime = await fetchCtftime(TEAM_ID);
const recentCompetitions = ctftime.recentCompetitions.slice(0, 5);
---

<Layout
  title="Ch0wn3rs - Elite Cybersecurity Team"
  description="Ch0wn3rs is an elite cybersecurity focused on CTF competitions, ethical hacking, digital forensics, and practical security training."
  image="/Logo-qr.jpeg"
>
  <!-- Hero Section -->
  <section id="home" class="hero">
    <div id="about" class="about-anchor" aria-hidden="true"></div>
    <div class="hero-stage">
      <div class="hero-background-stack" aria-hidden="true">
        <canvas id="matrixCanvas" class="hero-background hero-background-matrix"></canvas>
        <div class="hero-globe-shell">
          <canvas id="globeCanvas" class="hero-globe"></canvas>
        </div>
        <div class="hero-vignette"></div>
      </div>

      <div class="container hero-panel">
        <div class="hero-content">
          <div class="brand-identity">
            <img src="/Logo-qr.jpeg" alt="ch0wn3rs" class="brand-logo">
            <h1 class="brand-name">CH0WN3RS</h1>
          </div>
          <p class="hero-subtitle">Elite Cybersecurity Team</p>
          <p class="hero-description">
            We are the digital guardians, the code breakers, the system architects. 
            Join us in the relentless pursuit of cybersecurity excellence.
          </p>
        </div>

        <div class="hero-stats">
          <div class="stats-card">
            <div class="best-badge">
              <i class="ph ph-trophy"></i>
              <span class="badge-text" id="colombiaRank">{ctftime.colombiaRank}</span>
              <span class="flag">🇨🇴</span>
            </div>

            <div class="stat-item">
              <i class="ph ph-globe"></i>
              <div class="stat-content">
                <span class="stat-label">Global Rank</span>
                <span class="stat-value" id="globalRank">{ctftime.globalRank}</span>
              </div>
            </div>

            <div class="stat-item">
              <i class="ph ph-chart-line"></i>
              <div class="stat-content">
                <span class="stat-label">Rating</span>
                <span class="stat-value" id="rating">{ctftime.rating}</span>
              </div>
            </div>

            <div class="stat-item">
              <i class="ph ph-calendar-check"></i>
              <div class="stat-content">
                <span class="stat-label">Active Since</span>
                <span class="stat-value" id="yearPoints">{ctftime.activeSince}</span>
              </div>
            </div>

            <a href="https://ctftime.org/team/408704" target="_blank" class="ctftime-link">
              View on CTFtime <i class="ph ph-arrow-square-out"></i>
            </a>

            <p class="ctftime-attribution">Powered by CTFtime</p>
          </div>
        </div>
      </div>

      <div class="about-panel">
        <div class="container">
          <div class="about-copy">
            <p>
              Ch0wn3rs is a professional competitive CTF team, we are moved by mastering the art of cybersecurity
              through intense competition. We are a tight-knit group of passionate individuals who thrive on solving
              complex security challenges under pressure. Our journey is defined by a commitment to excellence in the
              world of Capture The Flag (CTF) competitions and cybersecurity research.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { initGlobe, initMatrixCanvas } from '../lib/hero-effects';

    let cleanupGlobe;
    let cleanupMatrix;
    let cleanupResultsGlobe;
    let cleanupIntroScene;

    function initIntroScene() {
      const scene = document.querySelector('.hero');
      const heroPanel = scene?.querySelector('.hero-panel');
      const aboutPanel = scene?.querySelector('.about-panel');
      const globe = scene?.querySelector('.hero-globe-shell');
      if (!(scene && heroPanel instanceof HTMLElement && aboutPanel instanceof HTMLElement && globe instanceof HTMLElement)) {
        return undefined;
      }

      const EASE = 'cubic-bezier(0.22, 1, 0.36, 1)';
      const DUR = 560;
      const WHEEL_THRESHOLD = 50;
      const TOUCH_THRESHOLD = 50;
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const tf = (y = 0, rotate = 0, scale = 1) => `translateY(${y}px) rotate(${rotate}deg) scale(${scale})`;

      const pose = (el, opacity, y = 0, rotate = 0, scale = 1) => {
        el.style.opacity = String(opacity);
        el.style.transform = tf(y, rotate, scale);
      };

      const run = (el, from, to, duration, delay = 0, easing = EASE) => {
        const animation = el.animate([from, to], {
          duration,
          delay,
          easing,
          fill: 'forwards',
        });

        return animation.finished.then(() => {
          for (const [key, value] of Object.entries(to)) {
            el.style[key] = value;
          }
          animation.cancel();
        });
      };

      const centeredGlobeTransform = () => 'translate3d(-50%, -50%, 0)';
      const shiftedGlobeTransform = () => (
        window.innerWidth <= 768
          ? 'translate3d(calc(-50% - 33vw), -50%, 0)'
          : 'translate3d(calc(-50% - 36vw), -50%, 0)'
      );

      let current = 0;
      let transitioning = false;
      let wheelAcc = 0;
      let touchStartY = 0;

      const syncState = (index) => {
        current = index;
        scene.dataset.sceneState = index === 0 ? 'hero' : 'about';
        heroPanel.dataset.state = index === 0 ? 'active' : '';
        aboutPanel.dataset.state = index === 1 ? 'active' : '';
        heroPanel.style.zIndex = index === 0 ? '3' : '1';
        aboutPanel.style.zIndex = index === 1 ? '3' : '2';
        heroPanel.style.pointerEvents = index === 0 ? 'auto' : 'none';
        aboutPanel.style.pointerEvents = index === 1 ? 'auto' : 'none';

        if (index === 0) {
          pose(heroPanel, 1, 0, 0, 1);
          pose(aboutPanel, 0, 80, 0, 0.96);
          globe.style.transform = centeredGlobeTransform();
        } else {
          pose(heroPanel, 0, -100, 0, 0.96);
          pose(aboutPanel, 1, 0, 0, 1);
          globe.style.transform = shiftedGlobeTransform();
        }
      };

      const isScenePinned = () => {
        const rect = scene.getBoundingClientRect();
        return rect.top <= 0 && rect.bottom > window.innerHeight;
      };

      const goTo = (to) => {
        if (to === current || to < 0 || to > 1 || transitioning) return;

        transitioning = true;
        const from = current;
        const forward = to > from;
        const outEl = forward ? heroPanel : aboutPanel;
        const inEl = forward ? aboutPanel : heroPanel;

        current = to;
        scene.dataset.sceneState = to === 0 ? 'hero' : 'about';
        heroPanel.style.pointerEvents = 'none';
        aboutPanel.style.pointerEvents = 'none';

        outEl.style.zIndex = '2';
        inEl.style.zIndex = '3';

        if (prefersReducedMotion) {
          syncState(to);
          transitioning = false;
          return;
        }

        const outFrom = {
          opacity: '1',
          transform: tf(0, 0, 1),
        };
        const outTo = forward
          ? { opacity: '0', transform: tf(-100, 0, 0.96) }
          : { opacity: '0', transform: tf(80, 0, 0.96) };
        const inFrom = forward
          ? { opacity: '0', transform: tf(80, 0, 0.96) }
          : { opacity: '0', transform: tf(-100, 0, 0.96) };
        const inTo = {
          opacity: '1',
          transform: tf(0, 0, 1),
        };
        const globeFrom = {
          transform: forward ? centeredGlobeTransform() : shiftedGlobeTransform(),
        };
        const globeTo = {
          transform: forward ? shiftedGlobeTransform() : centeredGlobeTransform(),
        };
        const inDelay = forward ? DUR * 0.55 : DUR * 0.2;

        const outP = run(outEl, outFrom, outTo, DUR);
        const inP = run(inEl, inFrom, inTo, DUR, inDelay);
        const globeP = run(globe, globeFrom, globeTo, DUR);

        Promise.all([outP, inP, globeP]).then(() => {
          syncState(to);
          transitioning = false;
        });
      };

      const next = () => goTo(current + 1);
      const prev = () => goTo(current - 1);

      const onWheel = (event) => {
        if (!isScenePinned()) {
          wheelAcc = 0;
          return;
        }

        const direction = Math.sign(event.deltaY);
        const wantsNext = direction > 0 && current === 0;
        const wantsPrev = direction < 0 && current === 1;

        if (!(wantsNext || wantsPrev || transitioning)) {
          wheelAcc = 0;
          return;
        }

        event.preventDefault();
        if (transitioning) return;

        wheelAcc += event.deltaY;
        if (Math.abs(wheelAcc) < WHEEL_THRESHOLD) return;

        if (wheelAcc > 0) next();
        else prev();
        wheelAcc = 0;
      };

      const onTouchStart = (event) => {
        touchStartY = event.touches[0].clientY;
      };

      const onTouchEnd = (event) => {
        if (!isScenePinned() || transitioning) return;
        const dy = touchStartY - event.changedTouches[0].clientY;
        if (Math.abs(dy) < TOUCH_THRESHOLD) return;
        if (dy > 0 && current === 0) next();
        if (dy < 0 && current === 1) prev();
      };

      const onKeyDown = (event) => {
        if (!isScenePinned() || transitioning) return;

        if (current === 0 && (event.key === 'ArrowDown' || event.key === 'PageDown' || event.key === ' ')) {
          event.preventDefault();
          next();
        }

        if (current === 1 && (event.key === 'ArrowUp' || event.key === 'PageUp')) {
          event.preventDefault();
          prev();
        }
      };

      const onResize = () => {
        if (!transitioning) syncState(current);
      };

      const onAboutClick = (event) => {
        event.preventDefault();
        window.scrollTo({ top: 0, behavior: 'auto' });
        if (current !== 1) next();
      };

      const onHomeClick = (event) => {
        event.preventDefault();
        window.scrollTo({ top: 0, behavior: 'auto' });
        if (current !== 0) prev();
      };

      const aboutLinks = Array.from(document.querySelectorAll('a[href="#about"]'));
      const homeLinks = Array.from(document.querySelectorAll('a[href="#home"]'));

      syncState(window.location.hash === '#about' ? 1 : 0);

      window.addEventListener('wheel', onWheel, { passive: false });
      window.addEventListener('touchstart', onTouchStart, { passive: true });
      window.addEventListener('touchend', onTouchEnd, { passive: true });
      window.addEventListener('keydown', onKeyDown);
      window.addEventListener('resize', onResize);
      aboutLinks.forEach((link) => link.addEventListener('click', onAboutClick));
      homeLinks.forEach((link) => link.addEventListener('click', onHomeClick));

      return () => {
        window.removeEventListener('wheel', onWheel);
        window.removeEventListener('touchstart', onTouchStart);
        window.removeEventListener('touchend', onTouchEnd);
        window.removeEventListener('keydown', onKeyDown);
        window.removeEventListener('resize', onResize);
        aboutLinks.forEach((link) => link.removeEventListener('click', onAboutClick));
        homeLinks.forEach((link) => link.removeEventListener('click', onHomeClick));
      };
    }

    window.addEventListener('load', () => {
      cleanupMatrix?.();
      cleanupGlobe?.();
      cleanupResultsGlobe?.();
      cleanupIntroScene?.();

      cleanupMatrix = initMatrixCanvas('matrixCanvas');
      cleanupGlobe = initGlobe('globeCanvas');
      cleanupResultsGlobe = initGlobe('resultsGlobeCanvas', { tiltDegrees: 24 });
      cleanupIntroScene = initIntroScene();
    });

    window.addEventListener('beforeunload', () => {
      cleanupMatrix?.();
      cleanupGlobe?.();
      cleanupResultsGlobe?.();
      cleanupIntroScene?.();
    });
  </script>

  <script is:inline type="module">
    // Hydrate and refresh scoreboard every 10 minutes (client-side)
    (() => {
      const TEAM_ID = '408704';
      const INTERVAL = 10 * 60 * 1000; // 10 minutes

      async function hydrate() {
        try {
          const res = await fetch(`/api/ctftime?teamId=${TEAM_ID}`);
          if (!res.ok) throw new Error('Network response was not ok');
          const data = await res.json();

          if (data?.colombiaRank) document.getElementById('colombiaRank').textContent = data.colombiaRank;
          if (data?.globalRank) document.getElementById('globalRank').textContent = data.globalRank;
          if (data?.rating) document.getElementById('rating').textContent = data.rating;
          if (data?.activeSince) document.getElementById('yearPoints').textContent = data.activeSince;

          // mark when the client last updated the values
          const now = new Date().toISOString();
          document.querySelectorAll('[id="colombiaRank"], [id="globalRank"], [id="rating"], [id="yearPoints"]').forEach(el => el.setAttribute('data-ctf-updated', now));
        } catch (err) {
          console.debug('CTFtime client hydrate failed:', err);
        }
      }

      // hydrate immediately (client) then every INTERVAL
      hydrate();
      setInterval(hydrate, INTERVAL);
    })();
  </script>

  <script>
    import { animate, stagger } from 'animejs';

    document.addEventListener('DOMContentLoaded', () => {
      // Offensive Security: Binary Stream Background
      const binaryStream = document.getElementById('binaryStream');
      if (binaryStream) {
        const chars = '01';
        const streamSize = 1000;
        let content = '';
        for (let i = 0; i < streamSize; i++) {
          content += chars[Math.floor(Math.random() * chars.length)];
        }
        binaryStream.textContent = content;

        animate('#binaryStream', {
          opacity: [0.02, 0.08, 0.02],
          duration: 3000,
          loop: true,
          easing: 'easeInOutQuad'
        });
      }

      // Brute Force: Text Scramble Effect
      const scrambleLetters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%^&*()';
      
      function scrambleText(el: HTMLElement) {
        const originalText = el.textContent || '';
        const iterations = 10;
        let count = 0;

        const interval = setInterval(() => {
          el.textContent = originalText
            .split('')
            .map((char, index) => {
              if (index < count) return originalText[index];
              return scrambleLetters[Math.floor(Math.random() * scrambleLetters.length)];
            })
            .join('');

          if (count >= originalText.length) {
            clearInterval(interval);
            el.textContent = originalText;
          }
          count += originalText.length / iterations;
        }, 50);
      }

      // Staggered entrance for SERVICE cards only
      animate('.service-card', {
        translateY: [50, 0],
        scale: [0.95, 1],
        opacity: [0, 1],
        delay: stagger(100, {start: 500}),
        ease: 'easeOutExpo'
      });

      // Glitch effect for brand name
      const brandName = document.querySelector('.brand-name');
      if (brandName) {
        brandName.addEventListener('mouseenter', () => {
          animate(brandName, {
            translateX: [
              { to: -2, duration: 50 },
              { to: 2, duration: 50 },
              { to: -2, duration: 50 },
              { to: 0, duration: 50 }
            ],
            ease: 'easeInOutQuad',
            loop: 2
          });
        });
      }

      // Phase 4: Specialized Reveals for All Members
      const REVEAL_LOGS: Record<string, string[]> = {
        crypto: [
          '[+] INITIALIZING CRYPTO ANALYSIS...',
          '[!] DETECTING RSA-2048 KEY...',
          '[+] SCALE: 2^64 COMBINATIONS',
          '[+] RUNNING FREQUENCY ANALYSIS...',
          '[OK] KEY COLLISION FOUND AT ADDR: 0x' + Math.random().toString(16).substr(2, 4),
          '[+] DECRYPTING PAYLOAD...'
        ],
        ai: [
          '[+] ACCESSING NEURAL INTERFACE...',
          '[!] BYPASSING SILICON SAFETY LIMITS...',
          '[+] ANALYZING MODEL WEIGHTS FROM SRAM...',
          '[+] RECOVERING CLASSIFIER ENTROPY...',
          '[OK] BIOMETRIC OVERRIDE SUCCESSFUL',
          '[+] EXTRACTING IDENTITY VECTOR...'
        ],
        osint: [
          '[+] MAPPING DIGITAL FOOTPRINT...',
          '[!] PROCESSING LSB STENO-DATA...',
          '[+] ANALYZING SOCIAL GRAPH METADATA...',
          '[+] COORDINATES TRACED TO CH0W3RS_LAB',
          '[OK] ANONYMITY SHATTERED',
          '[+] REVEALING TARGET PROFILE...'
        ],
        reversing: [
          '[+] ATTACHING DEBUGGER TO PROCESS...',
          '[!] STACK OVERFLOW DETECTED AT 0x00401000',
          '[+] ANALYZING MEMORY ADDR: 0x' + Math.random().toString(16).substr(2, 8).toUpperCase(),
          '[!] BYPASSING DEP/ASLR...',
          '[OK] PAYLOAD DECRYPTED SUCCESSFULLY',
          '[+] EXTRACTING STRINGS...'
        ],
        forensics: [
          '[+] MOUNTING E01 IMAGE FILE...',
          '[!] RECOVERING DELETED SLACK SPACE...',
          '[+] PARSING NTFS MFT RECORDS...',
          '[+] ANALYZING SYSTEM LOG ENTROPY...',
          '[OK] HIDDEN ARTIFACTS RECOVERED',
          '[+] EXFILTRATING EVIDENCE...'
        ],
        pwn: [
          '[+] CONNECTING TO REMOTE SOCKET...',
          '[!] BUFFER OVERFLOW EXPLOIT SENT...',
          '[+] CORRUPTING EIP REGISTER...',
          '[+] ESCALATING PRIVILEGES TO ROOT',
          '[OK] SHELL ACCESS GRANTED',
          '[+] FETCHING /etc/shadow DATA...'
        ]
      };

      async function runSpecializedReveal(card: HTMLElement) {
        if (card.classList.contains('reversing-active') || card.classList.contains('revealed')) return;
        
        const specialty = card.getAttribute('data-specialty') || 'reversing';
        const lines = REVEAL_LOGS[specialty] || REVEAL_LOGS.reversing;
        const content = card.querySelector('.terminal-content') as HTMLElement;
        const overlay = card.querySelector('.terminal-overlay') as HTMLElement;
        
        if (!content || !overlay) return;

        // Ensure card is visible (override .animate-card opacity: 0)
        card.style.opacity = '1';
        card.classList.add('reversing-active');
        content.innerHTML = '';
        
        // Scanline animation
        const scanline = card.querySelector('.scanline');
        if (scanline) {
          animate(scanline, {
            translateY: ['0%', '1000%'],
            duration: 2000,
            loop: true,
            easing: 'linear'
          });
        }
        
        // Step-by-step terminal lines
        for (const line of lines) {
          const p = document.createElement('div');
          p.className = 'terminal-line';
          p.textContent = line;
          content.appendChild(p);
          
          await new Promise(r => setTimeout(r, 120 + Math.random() * 140)); // Slightly longer timing
          p.classList.add('active');
          
          if (line.includes('ANALYZING') || line.includes('PROCESSING') || line.includes('INITIALIZING')) {
            const dump = document.createElement('div');
            dump.style.fontSize = '0.6rem';
            dump.style.opacity = '0.5';
            content.appendChild(dump);
            for (let i = 0; i < 20; i++) { // Fewer chars for speed
              dump.textContent += (Math.random() > 0.5 ? '1' : '0');
              if (i % 10 === 0) await new Promise(r => setTimeout(r, 10));
            }
          }
        }

        // Final Flash
        animate(overlay, {
          backgroundColor: ['rgba(180, 180, 180, 0.22)', 'rgba(0, 0, 0, 0.95)'],
          duration: 400,
          easing: 'easeOutQuad'
        });

        // Reveal
        return new Promise<void>((resolve) => {
          setTimeout(() => {
            card.classList.remove('reversing-active');
            card.classList.add('revealed'); // Show the content (Name, Role, etc)
            
            // Trigger scramble on revealed elements
            card.querySelectorAll('[data-scramble]').forEach(el => {
              scrambleText(el as HTMLElement);
            });

            resolve();
          }, 500); // Slightly longer pause before reveal
        });
      }

      async function runPulseScan(card: HTMLElement) {
        if (card.classList.contains('reversing-active')) return;
        
        const content = card.querySelector('.terminal-content') as HTMLElement;
        const overlay = card.querySelector('.terminal-overlay') as HTMLElement;
        if (!content || !overlay) return;

        card.classList.add('reversing-active');
        content.innerHTML = '<div class="terminal-line active">[+] SYNCHRONIZING DATA...</div>';
        
        const scanline = card.querySelector('.scanline');
        if (scanline) {
          animate(scanline, {
            translateY: ['0%', '1000%'],
            duration: 500,
            easing: 'linear'
          });
        }

        // Quick Flash pulse
        animate(overlay, {
          backgroundColor: ['rgba(180, 180, 180, 0.16)', 'rgba(0, 0, 0, 0.95)'],
          duration: 300,
          easing: 'easeOutQuad'
        });

        setTimeout(() => {
          card.classList.remove('reversing-active');
          content.innerHTML = '';
        }, 500);
      }

      // IntersectionObserver for simultaneous reveal & smart re-entry
      const teamSection = document.getElementById('team');
      if (teamSection) {
        let hasInitialized = false;
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(async (entry) => {
            if (entry.isIntersecting && entry.intersectionRatio >= 0.1) {
              const cards = Array.from(document.querySelectorAll('.reversing-card')) as HTMLElement[];
              
              if (!hasInitialized) {
                // First time: reveal all cards at once
                hasInitialized = true;
                observer.unobserve(entry.target);
                await Promise.all(cards.map(card => runSpecializedReveal(card)));
                observer.disconnect(); // Ensure the animation can run only once
              }
            }
          });
        }, {
          threshold: [0.1],
          rootMargin: '0px 0px 0px 0px'
        }); // Start only when at least 10% of section is in view
        
        observer.observe(teamSection);
      }

      // Fallback: Still allow manual trigger on click if not already revealed
      document.querySelectorAll('.reversing-card').forEach(card => {
        card.addEventListener('click', () => {
          runSpecializedReveal(card as HTMLElement);
        });
      });

    });
  </script>

  <div class="post-intro-shell">
    <div class="post-intro-background" aria-hidden="true">
      <div class="results-globe-shell">
        <canvas id="resultsGlobeCanvas" class="results-globe"></canvas>
      </div>
    </div>

    <!-- Results Section -->
    <section id="results" class="results">
      <div class="container">
        <div class="results-header">
          <h2>Recent Competition</h2>
        </div>

        <div class="results-timeline" id="recentCompetitionsTimeline">
          {recentCompetitions.length > 0 ? recentCompetitions.map((competition) => (
            <article class="result-entry">
              <div class="result-marker">
                <div class="result-logo-shell">
                  {competition.logoUrl ? (
                    <img
                      class="result-logo"
                      src={competition.logoUrl}
                      alt={`${competition.title} logo`}
                      loading="lazy"
                    />
                  ) : (
                    <i class="ph ph-flag result-logo-fallback"></i>
                  )}
                </div>
              </div>

              <div class="result-card">
                <a
                  class="result-title"
                  href={competition.eventUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {competition.title}
                </a>

                <span class="result-rank-pill">
                  <i class="ph ph-trophy"></i>
                  #{competition.place}
                </span>

                <div class="result-footer">
                  <p class="result-date result-date-footer">{competition.dateLabel}</p>

                  <div class="result-points">
                    <span class="result-point-chip result-point-chip-ctf">
                      <i class="ph ph-flag"></i>
                      CTF {competition.ctfPoints}
                    </span>
                    <span class="result-point-chip result-point-chip-rating">
                      <i class="ph ph-chart-line-up"></i>
                      Rank {competition.ratingPoints}
                    </span>
                  </div>
                </div>
              </div>
            </article>
          )) : (
            <div class="result-empty">No top-30 finishes cached for 2026 yet.</div>
          )}
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
    <div class="container">
      <h2 class="section-title">What We Offer</h2>
      <div class="services-grid">
        <div class="service-card">
          <div class="service-icon"><i class="ph ph-target"></i></div>
          <h3>CTF Competitions</h3>
          <p>Regular Capture The Flag events to sharpen your skills and compete with the best minds in cybersecurity.</p>
        </div>
        <div class="service-card">
          <div class="service-icon"><i class="ph ph-users"></i></div>
          <h3>Community & Events</h3>
          <p>Join our active community, participate in meetups, conferences, and networking events with fellow security enthusiasts.</p>
        </div>
        <div class="service-card">
