    height: 1px;
  }

  .hero-stage {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    background: #000;
  }

  .hero-stage::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.88) 0%, rgba(0, 0, 0, 0.52) 38%, rgba(0, 0, 0, 0.78) 100%),
      radial-gradient(circle at 24% 48%, rgba(255, 40, 90, 0.12), transparent 32%);
    pointer-events: none;
    z-index: 0;
  }

  .hero-background-stack {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-background-matrix {
    opacity: 0.58;
    mix-blend-mode: screen;
  }

