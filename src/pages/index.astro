    position: absolute;
    top: 50%;
    left: 50%;
    width: min(68vw, 1040px);
    height: min(68vw, 1040px);
    transform: translate3d(-50%, -50%, 0);
    opacity: 0.9;
    filter: drop-shadow(0 0 40px rgba(220, 20, 60, 0.24));
    will-change: transform, opacity;
  }

  .hero-globe {
    width: 100%;
    height: 100%;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background:
