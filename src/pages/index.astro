    }

    .hero-panel {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 80px 1rem 40px;
      min-height: 100%;
      align-items: start;
    }
    
    .hero-content {
      order: 1;
    }
    
    .hero-stats {
      order: 2;
      width: 100%;
      margin-bottom: 2rem;
      padding: 0;
      max-width: 100%;
    }
    
    .stats-card {
      padding: 1.5rem;
      width: 100%;
      max-width: 92%;
      margin: 0 auto;
    }
    
    .best-badge {
      font-size: 1rem;
      padding: 1rem 0.8rem;
      gap: 0.5rem;
    }
    
    .best-badge i {
      font-size: 1.5rem;
    }
    
    .best-badge .flag {
      font-size: 1.3rem;
    }
    
    .stat-item {
      padding: 0.8rem;
    }

    .stat-item i {
      font-size: 1.5rem;
    }
    
    .stat-value {
      font-size: 1.3rem;
    }

    .stat-label {
      font-size: 0.85rem;
    }
    
    .brand-identity {
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    
    .brand-logo {
      width: 100px;
      height: 100px;
    }
    
    .brand-name {
      font-size: 2.5rem;
      letter-spacing: 2px;
    }
    
    .hero-subtitle {
      font-size: 1.2rem;
      letter-spacing: 2px;
      margin-bottom: 1.5rem;
    }
    
    .hero-description {
      font-size: 0.95rem;
      line-height: 1.6;
      margin-bottom: 2rem;
      padding: 0;
    }
    
    .hero-buttons {
      flex-direction: column;
      padding: 0;
      gap: 1rem;
    }
    
    .hero-buttons .btn {
      width: 100%;
    }
    
    .about-panel {
      padding: 5rem 16px;
    }

    .about-panel .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .about-copy p {
      font-size: 1rem;
      line-height: 1.8;
    }
    
    .results {
      padding: 90px 16px 120px;
    }

    .results-header {
      margin-bottom: 2.5rem;
    }

    .results-globe-shell {
      top: 52%;
      width: min(196vw, 1120px);
      height: min(196vw, 1120px);
      opacity: 0.34;
    }

    .results-timeline {
      padding-left: 0;
    }

    .results-timeline::before {
      display: none;
    }

    .result-entry {
      grid-template-columns: 1fr;
      gap: 0.9rem;
    }

    .result-marker {
      justify-content: flex-start;
      padding-left: 1rem;
    }

    .result-card {
      padding: 1.25rem;
    }

    .result-footer {
      flex-direction: column;
      align-items: flex-start;
    }

    .result-points {
      justify-content: flex-start;
    }

    .result-empty {
      margin-left: 0;
    }
    
    .services-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .services .container {
      padding-left: 0;
      padding-right: 0;
