  }

  .result-empty {
    padding: 1.35rem 1.5rem;
    border-radius: 18px;
    background: rgba(26, 26, 26, 0.94);
    border: 1px dashed rgba(220, 20, 60, 0.3);
    color: rgba(255, 255, 255, 0.68);
    margin-left: 4.75rem;
  }
  
  /* Accordion Styles */
  .accordion-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .accordion-item {
    background: rgba(220, 20, 60, 0.03);
    border: 1px solid rgba(220, 20, 60, 0.2);
    border-radius: 8px;
    overflow: hidden;
    transition: all 0.3s ease;
  }
  
  .accordion-item.active {
    border-color: rgba(220, 20, 60, 0.5);
    background: rgba(220, 20, 60, 0.08);
  }
  
  .accordion-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    user-select: none;
  }
  
  .accordion-header:hover {
    background: rgba(220, 20, 60, 0.05);
  }
  
  .accordion-icon {
    font-size: 1.5rem;
    color: var(--primary-red);
    filter: drop-shadow(0 0 8px rgba(220, 20, 60, 0.6));
  }
  
  .accordion-header h4 {
    flex: 1;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--primary-red);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0;
  }
  
  .accordion-arrow {
    font-size: 1.2rem;
    color: var(--primary-red);
    transition: transform 0.3s ease;
  }
  
  .accordion-item.active .accordion-arrow {
    transform: rotate(180deg);
  }
  
  .accordion-content {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s ease;
    padding: 0 1.5rem;
  }
  
  .accordion-item.active .accordion-content {
    max-height: 500px;
    padding: 0 1.5rem 1.5rem;
  }
  
  .accordion-content p {
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1rem;
    line-height: 1.6;
  }
  
  .skill-details {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .skill-details li {
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    position: relative;
  }
  
  .skill-details li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--primary-red);
    font-weight: bold;
  }
  
  /* Services Section */
  .services {
    position: relative;
    z-index: 1;
    padding: 100px 20px;
    background-color: transparent;
    margin: 20px 0;
  }

  .services .container {
    max-width: 1360px;
    margin: 0 auto;
    padding-left: 5.9rem;
    padding-right: 0.5rem;
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 380px));
    justify-content: center;
    gap: 2rem;
  }
  
  .service-card {
    background: rgba(26, 26, 26, 0.94);
    padding: 2rem;
    border-radius: 18px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .services-grid > :nth-child(4):last-child {
    grid-column: 2;
  }
  
  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 2px;
    background-color: var(--primary-red);
    transition: left 0.3s ease;
  }
  
  .service-card:hover::before {
    left: 0;
  }
  
  .service-card:hover {
    transform: translateY(-5px);
    border-color: rgba(220, 20, 60, 0.45);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.42);
  }
  
  .service-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .service-icon i {
    color: var(--primary-red);
    font-size: 3rem;
  }
  
  .service-card h3 {
    color: var(--primary-red);
    margin-bottom: 1rem;
    font-size: 1.3rem;
  }
  
  .service-card p {
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.6;
  }

  .ctf-platform-card {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  /* Skills Section */
  .skills {
    position: relative;
    z-index: 1;
    padding: 100px 20px;
    background-color: transparent;
    margin: 20px 0;
  }

  .skills.skills-dialog-active {
    z-index: 25;
  }

  .skills .container {
    max-width: 1480px;
    margin: 0 auto;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .skill-card {
    background: rgba(26, 26, 26, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
    padding: 1.35rem;
    min-height: 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .skill-card:hover {
    transform: translateY(-5px);
    border-color: rgba(220, 20, 60, 0.45);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.42);
  }

  .skill-card:focus-visible {
    outline: 2px solid rgba(220, 20, 60, 0.65);
    outline-offset: 4px;
  }

  .skill-card-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.15rem;
    margin-bottom: 0;
    text-align: center;
  }

  .skill-card-header i {
    color: var(--primary-red);
    font-size: 3.8rem;
  }

  .skill-card h3 {
    margin: 0;
    color: var(--primary-red);
    font-size: 1.55rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    line-height: 1.15;
  }

  .skill-card-summary {
    margin: 1.1rem 0 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.92rem;
    line-height: 1.55;
    text-align: center;
  }

  .skills .skill-details {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .skills .skill-details li {
    padding: 0.15rem 0 0.15rem 1.15rem;
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .skills-dialog[hidden] {
    display: none;
  }

  .skills-dialog {
    position: fixed;
    inset: 0;
    z-index: 1200;
    display: grid;
    place-items: center;
    padding: 1.5rem;
  }

  .skills-dialog-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(8px);
  }

  .skills-dialog-panel {
    position: relative;
    z-index: 1;
    width: min(75vw, 1200px);
    height: min(75vh, 820px);
    overflow: hidden;
    background: rgba(26, 26, 26, 0.96);
    border: 1px solid rgba(220, 20, 60, 0.28);
    border-radius: 22px;
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.56);
    padding: 1rem;
  }

  .skills-dialog-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 3;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgba(220, 20, 60, 0.28);
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.04);
    color: var(--primary-red);
    cursor: pointer;
    pointer-events: auto;
  }

  .skills-dialog-close i {
    font-size: 1.1rem;
  }

  .skills-dialog-body {
    height: 100%;
    padding-top: 0.25rem;
  }

  .skills-dialog-layout {
    display: grid;
    grid-template-columns: minmax(220px, 0.34fr) minmax(0, 1fr);
    height: 100%;
    min-height: 0;
  }

  .skills-dialog-sidebar {
    padding: 1.5rem 1.35rem 1.5rem 1rem;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
    overflow: auto;
  }

  .skills-dialog-visual {
    display: flex;
    flex-direction: column;
    min-width: 0;
    min-height: 0;
  }

  .skills-dialog-visual-stage {
    position: relative;
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .skills-dialog-globe {
    width: min(100%, 480px);
    height: min(100%, 480px);
    opacity: 0.58;
  }

  .skills-dialog-copy {
    padding: 1.25rem 1.5rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .skills-dialog-copy p {
    margin: 0;
    color: rgba(255, 255, 255, 0.94);
    line-height: 1.75;
  }

  .skills-dialog-header {
    flex-direction: row;
    margin-right: 0;
    margin-bottom: 1.5rem;
    align-items: flex-start;
    text-align: left;
  }

  .skills-dialog-body .skill-details {
    gap: 0.75rem;
  }

  .skills-dialog-body .skill-details li {
    font-size: 0.98rem;
    padding: 0.2rem 0 0.2rem 1.25rem;
  }

  @media (max-width: 1280px) {
    .skills-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* Team Section */
  .team {
    position: relative;
    z-index: 1;
    padding: 100px 20px;
    background-color: transparent;
    margin: 20px 0;
  }
  
  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .team-member {
    background-color: rgba(26, 26, 26, 0.94);
    padding: 2rem;
    border-radius: 8px;
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.32);
    transition: all 0.3s ease;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.9rem;
  }
  
  .team-member:hover {
    transform: translateY(-5px);
    border-color: var(--primary-red);
  }

  .member-avatar {
    font-size: 4rem;
    margin-bottom: 0.5rem;
  }

  .member-avatar i {
    color: var(--primary-red);
    font-size: 4rem;
  }

  .member-avatar-image {
    width: 112px;
    height: 112px;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(6, 7, 14, 0.96);
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.32);
  }

  .member-avatar-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .member-avatar-fallback {
    display: none;
    width: 100%;
    height: 100%;
    align-items: center;
    justify-content: center;
  }
  
  .team-member h3 {
    font-size: 1.4rem;
    letter-spacing: 0.05em;
    line-height: 1.15;
    font-weight: 700;
    margin: 0;
  }
  
  .member-email {
    font-size: 0.8rem;
    color: var(--primary-red);
    margin-top: 0;
    font-weight: bold;
    word-break: break-word;
  }

  .team-actions {
    display: flex;
    justify-content: center;
    margin-top: 2.25rem;
  }

  .team-view-all {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 140px;
    padding: 0.9rem 1.5rem;
    border-radius: 999px;
    border: 1px solid rgba(220, 20, 60, 0.35);
    background: rgba(26, 26, 26, 0.94);
    color: var(--primary-red);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.04em;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .team-view-all:hover {
    transform: translateY(-2px);
    border-color: rgba(220, 20, 60, 0.55);
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.3);
  }
  
  /* Social Media Section */
  .social-media {
    position: relative;
    z-index: 1;
    padding: 100px 20px;
    background-color: transparent;
    margin: 20px 0;
  }
  
  .social-subtitle {
    text-align: center;
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 4rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .social-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .social-card {
    background: rgba(26, 26, 26, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 18px;
    padding: 3rem 2rem;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }
  
  .social-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(220, 20, 60, 0.1), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  
  .social-card:hover::before {
    opacity: 1;
  }
  
  .social-card:hover {
    transform: translateY(-10px);
    border-color: rgba(220, 20, 60, 0.6);
    box-shadow: 0 24px 50px rgba(0, 0, 0, 0.42);
    background: rgba(26, 26, 26, 0.97);
  }
  
  .social-icon {
    width: 100px;
    height: 100px;
    margin: 0 auto 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle, rgba(220, 20, 60, 0.2), transparent);
    border-radius: 50%;
    border: 2px solid rgba(220, 20, 60, 0.3);
    transition: all 0.4s ease;
  }
  
  .social-card:hover .social-icon {
    transform: scale(1.1) rotate(5deg);
    border-color: rgba(220, 20, 60, 0.6);
    box-shadow: 0 0 30px rgba(220, 20, 60, 0.5);
  }
  
  .social-icon i {
    font-size: 3.5rem;
    color: var(--primary-red);
    filter: drop-shadow(0 0 10px rgba(220, 20, 60, 0.8));
    transition: all 0.4s ease;
  }
  
  .social-card:hover .social-icon i {
    filter: drop-shadow(0 0 20px rgba(220, 20, 60, 1));
  }
  
  .social-card h3 {
    font-size: 1.5rem;
    color: var(--primary-red);
    margin-bottom: 0.5rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 700;
  }
  
  .social-card p {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    transition: color 0.3s ease;
  }
  
  .social-card:hover p {
    color: rgba(255, 255, 255, 0.9);
  }
  
  
  /* Footer */
  .footer {
    position: relative;
    z-index: 1;
    background-color: var(--black);
    padding: 3rem 20px 1rem;
    border-top: 2px solid var(--primary-red);
  }
  
  .footer-content {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    margin-bottom: 2rem;
  }
  
  .footer-brand .logo {
    color: var(--primary-red);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  
  .footer-tagline {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 0.5rem;
    font-style: italic;
  }
  
  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  
  .footer-column h4 {
    color: var(--primary-red);
    margin-bottom: 1rem;
  }
  
  .footer-column ul {
    list-style: none;
  }
  
  .footer-column li {
    margin-bottom: 0.5rem;
  }
  
  .footer-column a {
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.3s ease;
    font-size: 0.95rem;
  }
  
  .footer-column a:hover {
    color: var(--primary-red);
  }
  
  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid var(--light-gray);
    text-align: center;
  }
  
  .footer-bottom p {
    margin: 0.5rem 0;
  }
  
  .footer-subtitle {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.5rem;
  }
  
  .footer-warning {
    color: var(--primary-red);
    font-weight: bold;
  }

  .footer-warning i {
    color: var(--primary-red);
    font-size: 1rem;
    vertical-align: middle;
  }
  
  /* Responsive Design */
  @media (max-width: 768px) {
    .hero {
      min-height: 126vh;
      height: auto;
      padding: 0;
    }

    .hero-stage::after {
      background:
        linear-gradient(180deg, rgba(0, 0, 0, 0.74) 0%, rgba(0, 0, 0, 0.58) 38%, rgba(0, 0, 0, 0.82) 100%),
        radial-gradient(circle at 50% 28%, rgba(255, 40, 90, 0.1), transparent 34%);
    }

    .hero-globe-shell {
      top: 50%;
      left: 50%;
      right: auto;
      width: min(86vw, 620px);
      height: min(86vw, 620px);
      transform: translate3d(-50%, -50%, 0);
      opacity: 0.64;
    }

    .hero-vignette {
      background:
        radial-gradient(circle at 50% 28%, rgba(255, 50, 95, 0.16), transparent 24%),
